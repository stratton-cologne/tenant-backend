{
  "name": "Tickets",
  "slug": "tickets",
  "version": "1.0.1",
  "description": "Tenant ticketing module (MVP).",
  "permissions": [
    "tickets.read",
    "tickets.create",
    "tickets.update",
    "tickets.delete",
    "tickets.assign",
    "tickets.status.update",
    "tickets.comment.create",
    "tickets.comment.delete",
    "tickets.category.manage",
    "tickets.tag.manage",
    "tickets.type.manage",
    "tickets.queue.manage",
    "tickets.attachment.upload",
    "tickets.attachment.read",
    "tickets.sla.manage",
    "tickets.report.read"
  ],
  "widgets": [
    "tickets.my_open",
    "tickets.sla_breaches"
  ],
  "lifecycle": {
    "file": "backend/tenant/TicketsModuleLifecycle.php",
    "class": "Modules\\Tickets\\Tenant\\TicketsModuleLifecycle"
  },
  "tenant_backend": {
    "routes": {
      "api": [
        "backend/tenant/routes/api.php"
      ]
